        "def ensure_headers(ws):\n",
        "    rows = ws.get_all_values()\n",
        "\n",
        "    if not rows:\n",
        "        ws.append_row(REQUIRED_COLUMNS, value_input_option=\"USER_ENTERED\")\n",
        "        return\n",
        "\n",
        "    header = rows[0]\n",
        "\n",
        "    if header != REQUIRED_COLUMNS:\n",
        "        old_records = ws.get_all_records()\n",
        "        ws.clear()\n",
        "        ws.append_row(REQUIRED_COLUMNS, value_input_option=\"USER_ENTERED\")\n",
        "\n",
        "        for record in old_records:\n",
        "            row = [\n",
        "                record.get(\"任務名稱\", \"\"),\n",
        "                record.get(\"截止日期\", \"\"),\n",
        "                record.get(\"優先順序\", \"\"),\n",
        "                record.get(\"備註\", \"\"),\n",
        "                record.get(\"來源網址\", \"\"),\n",
        "                record.get(\"建立時間\", \"\"),\n",
        "                record.get(\"番茄鐘次數\", 0),\n",
        "                record.get(\"任務狀態\", \"未完成\")\n",
        "            ]\n",
        "            ws.append_row(row, value_input_option=\"USER_ENTERED\")\n",
        "\n",
        "\n",
        "def connect_sheet():\n",
        "    global _auth_done, _gc, _ws\n",
        "\n",
        "    if not _auth_done:\n",
        "        auth.authenticate_user()\n",
        "        creds, _ = default()\n",
        "        _gc = gspread.authorize(creds)\n",
        "        _auth_done = True\n",
        "\n",
        "    if _ws is None:\n",
        "        sheet = _gc.open_by_url(SHEET_URL)\n",
        "        _ws = sheet.worksheet(WORKSHEET_NAME)\n",
        "        ensure_headers(_ws)\n",
        "\n",
        "    return _ws\n",
