        "TODO_KEYWORDS = [\n",
        "    \"作業\", \"繳交\", \"截止\", \"期限\", \"上傳\", \"報告\",\n",
        "    \"心得\", \"學習單\", \"任務\", \"完成\", \"繳交期限\",\n",
        "    \"assignment\", \"assignments\",\n",
        "    \"homework\", \"project\", \"projects\",\n",
        "    \"task\", \"tasks\", \"submit\", \"submission\",\n",
        "    \"due\", \"deadline\", \"complete\", \"finish\",\n",
        "    \"exercise\", \"lab\", \"problem set\", \"pset\"\n",
        "]\n",
        "\n",
        "HIGH_PRIORITY_KEYWORDS = [\n",
        "    \"今天\", \"明天\", \"逾期\", \"立即\", \"重要\", \"期末\", \"考試\",\n",
        "    \"today\", \"tomorrow\", \"urgent\", \"final\"\n",
        "]\n",
        "\n",
        "\n",
        "def contains_todo(text):\n",
        "    text = text.lower()\n",
        "\n",
        "    if any(keyword.lower() in text for keyword in TODO_KEYWORDS):\n",
        "        return True\n",
        "\n",
        "    if re.search(r\"(week\\s*\\d+|project\\s*\\d+|final project|problem set|pset)\", text):\n",
        "        return True\n",
        "\n",
        "    return False\n",
        "\n",
        "\n",
        "def extract_deadline(text):\n",
        "    patterns = [\n",
        "        r\"\\d{4}[/-]\\d{1,2}[/-]\\d{1,2}\",\n",
        "        r\"\\d{1,2}[/-]\\d{1,2}\",\n",
        "        r\"\\d{1,2}月\\d{1,2}日\",\n",
        "        r\"今天\",\n",
        "        r\"明天\",\n",
        "        r\"today\",\n",
        "        r\"tomorrow\"\n",
        "    ]\n",
        "\n",
        "    for pattern in patterns:\n",
        "        match = re.search(pattern, text.lower())\n",
        "\n",
        "        if match:\n",
        "            date_text = match.group()\n",
        "\n",
        "            parsed = dateparser.parse(\n",
        "                date_text,\n",
        "                languages=[\"zh\", \"en\"],\n",
        "                settings={\n",
        "                    \"RELATIVE_BASE\": datetime.datetime.now(),\n",
        "                    \"PREFER_DATES_FROM\": \"future\"\n",
        "                }\n",
        "            )\n",
        "\n",
        "            if parsed:\n",
        "                return parsed.strftime(\"%Y-%m-%d\")\n",
        "\n",
        "            return date_text\n",
        "\n",
        "    return \"未明確標示\"\n",
        "\n",
        "\n",
        "def decide_priority(text, deadline):\n",
        "    text = text.lower()\n",
        "\n",
        "    if any(keyword in text for keyword in HIGH_PRIORITY_KEYWORDS):\n",
        "        return \"高\"\n",
        "\n",
        "    if deadline != \"未明確標示\":\n",
        "        try:\n",
        "            deadline_date = datetime.datetime.strptime(deadline, \"%Y-%m-%d\").date()\n",
        "            today = datetime.date.today()\n",
        "            days_left = (deadline_date - today).days\n",
        "\n",
        "            if days_left <= 2:\n",
        "                return \"高\"\n",
        "            elif days_left <= 7:\n",
        "                return \"中\"\n",
        "            else:\n",
        "                return \"低\"\n",
        "\n",
        "        except:\n",
        "            return \"中\"\n",
        "\n",
        "    return \"中\""
      ],
