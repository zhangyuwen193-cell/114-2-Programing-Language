        "def parse_task_index(task_choice):\n",
        "    if not task_choice:\n",
        "        return None\n",
        "\n",
        "    match = re.match(r\"(\\d+)\\.\", task_choice)\n",
        "\n",
        "    if not match:\n",
        "        return None\n",
        "\n",
        "    return int(match.group(1))\n",
        "\n",
        "\n",
        "def add_pomodoro_count(task_choice):\n",
        "    task_index = parse_task_index(task_choice)\n",
        "\n",
        "    if task_index is None:\n",
        "        return \"請先選擇任務\", load_tasks(), gr.update(choices=get_task_choices())\n",
        "\n",
        "    ws = connect_sheet()\n",
        "\n",
        "    row_number = task_index + 1\n",
        "    tomato_col = REQUIRED_COLUMNS.index(\"番茄鐘次數\") + 1\n",
        "\n",
        "    current_value = ws.cell(row_number, tomato_col).value\n",
        "\n",
        "    try:\n",
        "        current_value = int(current_value)\n",
        "    except:\n",
        "        current_value = 0\n",
        "\n",
        "    ws.update_cell(row_number, tomato_col, current_value + 1)\n",
        "\n",
        "    return f\"✅ 已完成 1 顆番茄鐘，目前累積：{current_value + 1} 顆\", load_tasks(), gr.update(choices=get_task_choices())\n",
        "\n",
        "\n",
        "def mark_task_done(task_choice):\n",
        "    task_index = parse_task_index(task_choice)\n",
        "\n",
        "    if task_index is None:\n",
        "        return \"請先選擇任務\", load_tasks(), gr.update(choices=get_task_choices())\n",
        "\n",
        "    ws = connect_sheet()\n",
        "\n",
        "    row_number = task_index + 1\n",
        "    status_col = REQUIRED_COLUMNS.index(\"任務狀態\") + 1\n",
        "\n",
        "    ws.update_cell(row_number, status_col, \"已完成\")\n",
        "\n",
        "    return \"✅ 任務已標記為完成\", load_tasks(), gr.update(choices=get_task_choices())\n",
        "\n",
        "\n",
        "def start_pomodoro(task_choice, minutes):\n",
        "    if not task_choice:\n",
        "        yield \"請先選擇任務\"\n",
        "        return\n",
        "\n",
        "    try:\n",
        "        total_seconds = int(float(minutes) * 60)\n",
        "    except:\n",
        "        yield \"請輸入正確分鐘數\"\n",
        "        return\n",
        "\n",
        "    if total_seconds <= 0:\n",
        "        yield \"分鐘數必須大於 0\"\n",
        "        return\n",
        "\n",
        "    yield f\"🍅 番茄鐘開始！\\n目前任務：{task_choice}\\n剩餘時間：{minutes} 分鐘\"\n",
        "\n",
        "    while total_seconds > 0:\n",
        "        mins = total_seconds // 60\n",
        "        secs = total_seconds % 60\n",
        "\n",
        "        yield f\"🍅 專注中\\n目前任務：{task_choice}\\n剩餘時間：{mins:02d}:{secs:02d}\"\n",
        "\n",
        "        time.sleep(1)\n",
        "        total_seconds -= 1\n",
        "\n",
        "    yield f\"✅ 番茄鐘完成！\\n目前任務：{task_choice}\\n請按「完成一顆番茄鐘」來記錄。\"\n",
        "\n",
        "\n",
        "def refresh_all():\n",
        "    return load_tasks(), gr.update(choices=get_task_choices())"
