        "def generate_task(title, text, links, url):\n",
        "    if not contains_todo(text):\n",
        "        return None\n",
        "\n",
        "    deadline = extract_deadline(text)\n",
        "    priority = decide_priority(text, deadline)\n",
        "\n",
        "    note = text[:300]\n",
        "\n",
        "    if links:\n",
        "        note += \"\\n\\n相關連結：\\n\" + \"\\n\".join(links[:5])\n",
